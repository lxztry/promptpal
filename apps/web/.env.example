# ===========================================
# PromptPal - 环境变量配置
# 复制此文件为 .env.local 并填写真实值
# ===========================================

# 数据库
DATABASE_URL="postgresql://user:password@localhost:5432/promptpal"

# NextAuth 配置
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# OAuth 配置 (可选)
# ===========================================

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 微信登录
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

# ===========================================
# AI API Keys (可选，用户也可自行配置)
# ===========================================

# OpenAI (GPT-4o, DALL-E)
OPENAI_API_KEY=""

# Anthropic (Claude)
ANTHROPIC_API_KEY=""

# Stability AI (SDXL)
STABILITY_API_KEY=""

# Runway (视频生成)
RUNWAY_API_KEY=""

# Replicate (各种开源模型)
REPLICATE_API_TOKEN=""

# Google AI (Veo, Gemini)
GOOGLE_AI_API_KEY=""

# Luma AI
LUMA_API_KEY=""

# ===========================================
# 微信支付配置 (可选，后续集成)
# ===========================================
# WECHAT_MCHID=""
# WECHAT_MCHKEY=""
# WECHAT_NOTIFY_URL=""
