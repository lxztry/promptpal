{
  "manifest_version": 3,
  "name": "PromptPal - AI Prompt Generator",
  "version": "1.0.0",
  "description": "Select any text and quickly generate AI image/video prompts with one click",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.midjourney.com/*",
        "*://*.pixiv.net/*",
        "*://*.discord.com/*",
        "*://*.twitter.com/*",
        "*://*.weibo.com/*",
        "*://*.xiaohongshu.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
