{
  "manifest_version": 3,
  "name": "PromptPal - AI提示词助手",
  "version": "1.0.0",
  "description": "选中网页内容，一键生成AI图像/视频提示词",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "commands"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "icons": {
    "128": "icons/icon128.svg"
  },
  "commands": {
    "open-promptpal": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "打开 PromptPal"
    }
  }
}
